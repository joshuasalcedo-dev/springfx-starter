<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/23.0.1"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="io.joshuasalcedo.desktop.controller.SettingsController"
      spacing="16" prefWidth="450" prefHeight="350">
    <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>

    <Label text="Settings" style="-fx-font-size: 18px; -fx-font-weight: 600;"/>

    <Separator/>

    <!-- Theme -->
    <VBox spacing="4">
        <Label text="Theme" style="-fx-font-size: 13px; -fx-font-weight: 600;"/>
        <ComboBox fx:id="themeComboBox" prefWidth="200"/>
    </VBox>

    <!-- Font Size -->
    <VBox spacing="4">
        <Label text="Font Size" style="-fx-font-size: 13px; -fx-font-weight: 600;"/>
        <ComboBox fx:id="fontSizeComboBox" prefWidth="200"/>
    </VBox>

    <Region VBox.vgrow="ALWAYS"/>

    <Separator/>

    <!-- Actions -->
    <HBox spacing="8" alignment="CENTER_RIGHT">
        <Button fx:id="cancelButton" text="Cancel" onAction="#onCancel"/>
        <Button fx:id="applyButton" text="Apply" onAction="#onApply" defaultButton="true"/>
    </HBox>
</VBox>
